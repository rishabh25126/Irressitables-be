# Server
PORT=5000
NODE_ENV=development
# Logging: trace|debug|info|warn|error|fatal (default: debug in development, info in production)
LOG_LEVEL=info
# Optional: force human-readable logs when NODE_ENV is not development
# LOG_PRETTY=true
# Ring buffer size for GET /logs (default 500, max 10000)
# LOG_BUFFER_MAX_LINES=500
# Enable GET /logs when NODE_ENV=production (off by default in prod)
# DEBUG_LOGS_ROUTE=true
# Optional: require X-Logs-Secret header to read /logs (recommended if DEBUG_LOGS_ROUTE=true)
# LOGS_ROUTE_SECRET=change-me

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/investment-platform

# JWT
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=investment-platform-docs

# Client
CLIENT_URL=http://localhost:3000
